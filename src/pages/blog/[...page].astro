---
import type { Page } from "astro";
import BlogList from "../../components/blog/list.astro";
import BlogPagination from "../../components/blog/pagination";
import Layout from "../../layouts/Paginated.astro";
import { getEntry, type CollectionEntry } from "astro:content";
import { getPublishedPosts } from "../../utils/posts";

type Props = {
  page: Page<CollectionEntry<"blog">>;
};

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  // Published posts only, already sorted newest-first.
  const posts = await getPublishedPosts();
  const page = await getEntry("pages", "blog");
  if (!page) return;
  return paginate(posts, {
    pageSize: "page_size" in page.data ? page.data.page_size : 6,
  });
}

const page = await getEntry("pages", "blog");
const frontmatter = page?.data;
const pagination = Astro.props.page;
const { data: posts } = pagination;
---

<Layout frontmatter={frontmatter}>
  <div class="mx-auto max-w-6xl px-8 py-16">
    <h1
      class="text-3xl md:text-4xl font-bold text-center mb-8"
      data-editable="text"
      data-prop="title"
    >
      {frontmatter.title}
    </h1>
    <div class="max-w-md mx-auto mb-8">
      <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
      <script is:inline src="/pagefind/pagefind-ui.js"></script>
      <div id="search"></div>
      <script is:inline>
        window.addEventListener("DOMContentLoaded", () => {
          new PagefindUI({ element: "#search", showSubResults: true });
        });
      </script>
    </div>
    <section>
      <BlogList posts={posts} />
      <BlogPagination pagination={pagination} />
    </section>
  </div>
</Layout>
